{
    "compilerOptions": {
        // Environment setup & latest features
        "lib": ["ESNext", "DOM"],
        "target": "ESNext",
        "module": "Preserve",
        "moduleDetection": "force",
        "jsx": "react-jsx",
        "allowJs": true,
        // Bundler mode
        "moduleResolution": "bundler",
        // "allowImportingTsExtensions": true,
        "verbatimModuleSyntax": true,
        // Best practices
        "strict": true,
        "skipLibCheck": true,
        "noFallthroughCasesInSwitch": true,
        "noUncheckedIndexedAccess": true,
        "noImplicitOverride": true,
        // Some stricter flags (disabled by default)
        "noUnusedLocals": false,
        "noUnusedParameters": false,
        "noPropertyAccessFromIndexSignature": false,
        "paths": {
            "@bundu/shared": ["./packages/shared/src/index.ts"],
            "@bundu/shared/*": ["./packages/shared/src/*"],
            "@bundu/server": ["./packages/server/src/index.ts"],
            "@bundu/server/*": ["./packages/server/src/*"],
            "@client/constants": ["./packages/client/src/constants.ts"],
            "@client/globals": ["./packages/client/src/globals.ts"],
            "@client/rendering/*": ["./packages/client/src/rendering/*"],
            "@client/assets/*": ["./packages/client/src/assets/*"],
            "@client/configs/*": ["./packages/client/src/configs/*"]
        },
        "outDir": "dist",
        "strictNullChecks": true
    },
    "include": ["packages", "tests"]
}
