{
    "name": "bundu.io",
    "module": "index.ts",
    "type": "module",
    "workspaces": ["packages/*"],
    "devDependencies": {
        "@types/bun": "latest",
        "@types/sat": "^0.0.35"
    },
    "peerDependencies": {
        "typescript": "~5.9.3"
    },
    "scripts": {
        "server": "bun run packages/server/src/index.ts",
        "build": "bun run ./build.ts",
        "start": "bun server.ts --hot",
        "start:frontend": "bun server.ts",
        "client": "bun run build && bun run start",
        "typecheck": "tsc --noEmit",
        "test": "bun test"
    }
}
