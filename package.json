{
    "name": "bundu.io",
    "module": "index.ts",
    "type": "module",
    "workspaces": ["packages/*"],
    "devDependencies": {
        "@types/bun": "latest",
        "@types/sat": "^0.0.35"
    },
    "peerDependencies": {
        "typescript": "~5.9.3"
    },
    "scripts": {
        "server": "bun run packages/server/src/index.ts",
        "build": "bun run ./build.ts",
        "start": "bun server.ts --hot",
        "client": "bun run build && bun run start",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "@msgpack/msgpack": "^3.1.2",
        "@pixi/devtools": "^2.0.1",
        "@rwh/keystrokes": "^1.5.6",
        "pixi-viewport": "^6.0.3",
        "pixi.js": "^8.14.3",
        "sat": "^0.9.0"
    }
}
