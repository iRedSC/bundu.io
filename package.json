{
    "name": "bundu.io",
    "module": "index.ts",
    "type": "module",
    "workspaces": ["packages/*"],
    "devDependencies": {
        "@biomejs/biome": "2.5.4",
        "@msgpack/msgpack": "^3.1.3",
        "@types/bun": "^1.3.14",
        "@types/sat": "^0.0.35"
    },
    "peerDependencies": {
        "typescript": "~5.9.3"
    },
    "scripts": {
        "dev": "bun run ./dev.ts",
        "server": "bun run packages/server/src/index.ts",
        "build": "bun run ./build.ts",
        "build:debug": "BUNDU_DEBUG=1 bun run ./build.ts",
        "check-prod-debug": "bun run ./scripts/check-prod-debug.ts",
        "serve-frontend": "bun static-server.ts --hot",
        "serve-frontend:prod": "bun static-server.ts",
        "client": "bun run build && bun run serve-frontend",
        "typecheck": "tsc --noEmit && bun run --cwd packages/figma-plugin typecheck",
        "lint": "biome lint .",
        "test": "bun test",
        "test:integration": "bun run scripts/ci/websocket-smoke.ts"
    }
}
