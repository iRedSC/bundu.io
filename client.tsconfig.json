{
    "compilerOptions": {
        "lib": ["ESNext", "DOM"],
        "target": "ESNext",
        "module": "Preserve",
        "moduleDetection": "force",
        "jsx": "react-jsx",
        "allowJs": true,
        "moduleResolution": "bundler",
        "verbatimModuleSyntax": true,
        "strict": true,
        "skipLibCheck": true,
        "noFallthroughCasesInSwitch": true,
        "noUncheckedIndexedAccess": true,
        "noImplicitOverride": true,
        "noUnusedLocals": false,
        "noUnusedParameters": false,
        "noPropertyAccessFromIndexSignature": false,
        "paths": {
            "@client/constants": ["./src/game/client/constants.ts"],
            "@lib/*": ["./src/game/lib/*"],
            "@shared/*": ["./src/game/shared/*"],
            "@client/globals": ["./src/game/client/globals.ts"],
            "@client/rendering/*": ["./src/game/client/rendering/*"],
            "@client/assets/*": ["./src/game/client/assets/*"],
            "@client/configs/*": ["./src/game/client/configs/*"]
        },
        "plugins": [
            {
                "transform": "typia/lib/transform"
            }
        ],
        "outDir": "dist",
        "strictNullChecks": true
    },
    "include": ["src/game/client", "src/game/lib", "src/game/shared"]
}
